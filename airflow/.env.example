# Copy to airflow/.env and fill in. docker compose reads this automatically.

# Your host user id, so files Airflow writes into the mounted repo aren't
# root-owned. On Linux: run `id -u` and paste the result. (50000 is the fallback.)
AIRFLOW_UID=50000

# DagsHub-hosted MLflow tracking + registry.
MLFLOW_TRACKING_URI=https://dagshub.com/<user>/<repo>.mlflow
MLFLOW_TRACKING_USERNAME=<your-dagshub-username>
MLFLOW_TRACKING_PASSWORD=<your-dagshub-token>
DAGSHUB_USER_TOKEN=<your-dagshub-token>

# Registered model name (matches tune.py / inference.py default).
MLFLOW_MODEL_NAME=weather-xgb
