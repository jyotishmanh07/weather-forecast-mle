# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and used by docker-compose.

# DagsHub — hosted MLflow tracking/registry + DVC remote (free).
# Tracking URI looks like: https://dagshub.com/<user>/<repo>.mlflow
MLFLOW_TRACKING_URI=https://dagshub.com/your-user/weather-forecast-mle.mlflow
MLFLOW_TRACKING_USERNAME=your-dagshub-user
MLFLOW_TRACKING_PASSWORD=your-dagshub-token
DAGSHUB_USER_TOKEN=your-dagshub-token

# MLflow Model Registry — model is served via the @champion alias.
MLFLOW_MODEL_NAME=weather-xgb
MLFLOW_BASELINE_MODEL_NAME=weather-lasso-baseline

# For fully-local dev without DagsHub, use a local SQLite store instead:
# MLFLOW_TRACKING_URI=sqlite:///mlflow.db
