# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and used by docker-compose.

# AWS — required for S3 artifact storage and ECS deployment
S3_BUCKET=weather-forecast-data-mle
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# MLflow Model Registry
MLFLOW_MODEL_NAME=weather-xgb
MLFLOW_MODEL_STAGE=Production
MLFLOW_BASELINE_MODEL_NAME=weather-lasso-baseline

# Overridden by docker-compose to point at the mlflow service.
# Only set this here if running the API outside of docker-compose.
# MLFLOW_TRACKING_URI=sqlite:///mlflow.db
